<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Compressor</title>
    <organization>com.socalabs</organization>
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>
    <options customize="always" require-scripts="false" rootVolumeOnly="true"/>
    <license file="EULA.rtf"/>
    <welcome    file="welcome.txt"   mime-type="text/plain"/>

    <choices-outline>
        <line choice="com.socalabs.compressor.vst"/>
        <line choice="com.socalabs.compressor.vst3"/>
        <line choice="com.socalabs.compressor.au"/>
        <line choice="com.socalabs.compressor.clap"/>
        <line choice="com.socalabs.compressor.resources"/>
    </choices-outline>

    <choice id="com.socalabs.compressor.vst"
            title="VST"
            description="Install the VST plug-in to /Library/Audio/Plug-Ins/VST"
            visible="true">
        <pkg-ref id="com.socalabs.compressor.vst.pkg"/>
    </choice>

    <choice id="com.socalabs.compressor.vst3"
            title="VST3"
            description="Install the VST3 plug-in to /Library/Audio/Plug-Ins/VST3"
            visible="true">
        <pkg-ref id="com.socalabs.compressor.vst3.pkg"/>
    </choice>

    <choice id="com.socalabs.compressor.au"
            title="Audio Unit"
            description="Install the Audio Unit plug-in to /Library/Audio/Plug-Ins/Components"
            visible="true">
        <pkg-ref id="com.socalabs.compressor.au.pkg"/>
    </choice>

    <choice id="com.socalabs.compressor.clap"
            title="CLAP"
            description="Install the CLAP plug-in to /Library/Audio/Plug-Ins/CLAP"
            visible="true">
        <pkg-ref id="com.socalabs.compressor.clap.pkg"/>
    </choice>
    <choice id="com.socalabs.compressor.resources"
            title="Factory Presets"
            description="Install factory content to /Library/Audio/Presets/SocaLabs/Compressor"
            visible="true"
            enabled="false"
            selected="true">
        <pkg-ref id="com.socalabs.compressor.resources.pkg"/>
    </choice>

    <pkg-ref id="com.socalabs.compressor.vst.pkg"  version="0">vst.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.compressor.vst3.pkg" version="0">vst3.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.compressor.au.pkg"   version="0">au.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.compressor.clap.pkg" version="0">clap.pkg</pkg-ref>
    <pkg-ref id="com.socalabs.compressor.resources.pkg" version="0">resources.pkg</pkg-ref>
</installer-gui-script>
